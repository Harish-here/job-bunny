# Secrets — must be ignored before init.js ever writes a token
.env

# Personal data — public repo ships sanitized templates (templates/, resume.example.json) instead
# resume.json: real contact details + work history (build-time source of truth)
# data/cache.json: live job pipeline (ratings, salary-band search URLs, Notion IDs)
resume.json
data/cache.json

# Profiles — all profile config/data is local-only; templates/ ships the seeds
profiles/
config.json

# Dependencies
node_modules/

# Per-run intermediate artifacts (regenerated each run)
jobs_raw_text.json
jobs_raw_decisions.json
jobs_raw_decisions.md
jobs_raw_checkpoint.json
jobs_raw_checkpoint.md
jobs_raw.json
filtered_jobs.json
new_jobs.json
structure_input.md
structure_passthrough.json

# OS / editor noise
.DS_Store

# Chrome remote-debug profile (local only)
.chrome-debug/
