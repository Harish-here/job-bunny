# Secrets — must be ignored before init.js ever writes a token
.env

# Personal data — public repo ships sanitized templates (templates/, resume.example.json) instead
# resume.json: real contact details + work history (build-time source of truth)
# data/cache.json: live job pipeline (ratings, salary-band search URLs, Notion IDs)
resume.json
data/cache.json

# Profiles — all profile config/data is local-only; templates/ ships the seeds
profiles/*
config.json

# Dependencies
node_modules/

# Per-run intermediate artifacts (regenerated each run)
jobs_raw_text.json
jobs_raw_decisions.json
jobs_raw_decisions.md
jobs_raw_checkpoint.json
jobs_raw_checkpoint.md
jobs_raw.json
filtered_jobs.json
new_jobs.json
structure_input.md
structure_passthrough.json

# OS / editor noise
.DS_Store

# Chrome remote-debug profile (local only)
.chrome-debug/

# profiles/rajni/ is a committed, synthetic fixture profile for live-testing the
# deterministic pipeline stages + onboarding reference (see profiles/rajni/README.md).
# Must come after every blanket rule above that would otherwise re-shadow these paths
# (gitignore is last-match-wins per path) — do not move these earlier in the file.
!profiles/rajni/
!profiles/rajni/resume.json
!profiles/rajni/data/jobs_raw.json

# P3 runner: per-run observability artifacts (checkpoints, result.json,
# heartbeat, logs) are regenerated every run — never committed, even for
# the rajni fixture.
profiles/rajni/data/runs/
