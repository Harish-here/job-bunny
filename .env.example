# Copy to .env (gitignored) and fill.
# Notion internal integration token (https://www.notion.so/my-integrations) — shared by all profiles
NOTION_TOKEN=
# Telegram bot token (from @BotFather) — shared across profiles; per-profile chat_id lives
# in profile.json, written by /notify-setup, never by hand.
TELEGRAM_BOT_TOKEN=
# NOTE (v0.7+): per-profile Notion IDs live in profiles/<name>/profile.json, written by
# scripts/init.js. NOTION_DB_ID / NOTION_PARENT_PAGE_ID below are only read by pre-v0.7
# legacy checkouts (no config.json) — leave them out on a fresh install.
