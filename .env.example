# Copy to .env (gitignored) and fill.
# Notion internal integration token (https://www.notion.so/my-integrations) — shared by all profiles
NOTION_TOKEN=
# Telegram bot token (from @BotFather) — shared across profiles by default; per-profile
# chat_id lives in profile.json, written by /notify-setup, never by hand.
TELEGRAM_BOT_TOKEN=
# Optional: give one profile its own separate bot instead of the shared one above
# (e.g. TELEGRAM_BOT_TOKEN_HARISH, TELEGRAM_BOT_TOKEN_UVASHREE) — /notify-setup writes
# this automatically if you choose "separate" when a shared token already exists.
# NOTE (v0.7+): per-profile Notion IDs live in profiles/<name>/profile.json, written by
# scripts/init.js. NOTION_DB_ID / NOTION_PARENT_PAGE_ID below are only read by pre-v0.7
# legacy checkouts (no config.json) — leave them out on a fresh install.
